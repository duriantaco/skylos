    {
      "id": "basic-unused-symbols",
      "path": "fixtures/basic_unused_symbols",
      "description": "Basic unused functions, classes, imports, and module variables should be found while referenced symbols stay alive.",
      "taxonomy": ["basic_detection"],
      "importance": "critical",
      "source": {
        "repo": "https://github.com/duriantaco/skylos",
        "license": "Apache-2.0",
        "notes": "Local deterministic fixture for core dead-code recall and precision."
      },
      "scan": {
        "confidence": 0,
        "grep_verify": true
      },
      "budget": {
        "max_seconds": 5.0
      },
      "expect": {
        "unused": [
          {"kind": "import", "file": "app.py", "symbol": "json"},
          {"kind": "function", "file": "app.py", "symbol": "unused_helper"},
