{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skylos Companion",
  "version": "0.1.0",
  "identifier": "dev.skylos.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skylos Companion",
        "width": 1380,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
