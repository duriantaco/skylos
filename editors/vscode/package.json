{
  "name": "skylos-vscode-extension",
  "displayName": "Skylos",
  "description": "VS Code extension for dead code detection, Python SAST, security scanning, and AI code review for Python, TypeScript, JavaScript, and Go.",
  "version": "0.5.0",
  "publisher": "oha",
  "icon": "icon.png",
  "repository": { "type": "git", "url": "https://github.com/duriantaco/skylos" },
  "homepage": "https://docs.skylos.dev",
  "bugs": { "url": "https://github.com/duriantaco/skylos/issues" },
  "license": "Apache-2.0",
  "engines": { "vscode": "^1.87.0" },
  "categories": ["Linters"],
  "keywords": [
    "python",
    "typescript",
    "javascript",
    "go",
    "sast",
    "security",
    "dead-code",
    "static-analysis",
    "secrets-detection",
    "ai-code-review",
    "vscode"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:python",
    "onLanguage:typescript",
    "onLanguage:typescriptreact",
    "onLanguage:javascript",
    "onLanguage:javascriptreact",
    "onLanguage:go",
    "onCommand:skylos.scan"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "skylos.scan", "title": "Skylos: Scan Workspace", "icon": "$(refresh)" },
      { "command": "skylos.fix", "title": "Skylos: Fix Issue with AI" },
      { "command": "skylos.refresh", "title": "Skylos: Refresh", "icon": "$(refresh)" },
      { "command": "skylos.clear", "title": "Skylos: Clear All Findings", "icon": "$(clear-all)" },
      { "command": "skylos.dismissIssue", "title": "Skylos: Dismiss AI Finding" },
      { "command": "skylos.removeImport", "title": "Skylos: Remove Unused Import" },
      { "command": "skylos.removeFunction", "title": "Skylos: Remove Unused Function" },
      { "command": "skylos.addToWhitelist", "title": "Skylos: Add to Whitelist" },
      { "command": "skylos.fixAll", "title": "Skylos: Auto-Fix All", "icon": "$(wand)" },
      { "command": "skylos.fixAllDryRun", "title": "Skylos: Auto-Fix Dry Run", "icon": "$(preview)" },
      { "command": "skylos.chatAboutFinding", "title": "Skylos: Ask AI About Finding", "icon": "$(comment-discussion)" },
      { "command": "skylos.clearChat", "title": "Skylos: Clear Chat", "icon": "$(clear-all)" },
      { "command": "skylos.dashboard", "title": "Skylos: Security Dashboard", "icon": "$(graph)" },
      { "command": "skylos.nextFinding", "title": "Skylos: Next Finding", "icon": "$(arrow-down)" },
      { "command": "skylos.prevFinding", "title": "Skylos: Previous Finding", "icon": "$(arrow-up)" },
      { "command": "skylos.exportReport", "title": "Skylos: Export Report", "icon": "$(export)" },
      { "command": "skylos.scanFile", "title": "Skylos: Scan This File", "icon": "$(file-code)" },
      { "command": "skylos.toggleDelta", "title": "Skylos: Toggle Delta Mode", "icon": "$(git-compare)" },
      { "command": "skylos.showFindingDetail", "title": "Skylos: Show Finding Detail", "icon": "$(info)" },
      { "command": "skylos.filterFindings", "title": "Skylos: Filter Findings", "icon": "$(filter)" },
      { "command": "skylos.clearFilter", "title": "Skylos: Clear Filter", "icon": "$(close)" },
      { "command": "skylos.refreshCommandCenter", "title": "Skylos: Refresh Command Center", "icon": "$(pulse)" },
      { "command": "skylos.commandCenterOpenDetail", "title": "Skylos: Open Command Center Detail", "icon": "$(info)" },
      { "command": "skylos.commandCenterApplySafeFix", "title": "Skylos: Apply Command Center Safe Fix", "icon": "$(wrench)" },
      { "command": "skylos.commandCenterDismiss", "title": "Skylos: Dismiss Command Center Action", "icon": "$(close)" },
      { "command": "skylos.commandCenterSnooze", "title": "Skylos: Snooze Command Center Action", "icon": "$(clock)" },
      { "command": "skylos.commandCenterRestoreTriaged", "title": "Skylos: Restore Triaged Command Center Action", "icon": "$(history)" },
      { "command": "skylos.fixDeadCode", "title": "Skylos: Preview Dead Code Removal", "icon": "$(trash)" }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "skylos",
          "title": "Skylos",
          "icon": "media/shield.svg"
        }
      ]
    },
    "views": {
      "skylos": [
        {
          "id": "skylosFindings",
          "name": "Findings",
          "icon": "$(shield)"
        },
        {
          "id": "skylosCommandCenter",
          "name": "Command Center",
          "icon": "$(pulse)"
        },
        {
          "type": "webview",
          "id": "skylosChatPanel",
          "name": "Security Copilot"
        }
      ]
    },
    "menus": {
      "view/title": [
        { "command": "skylos.refresh", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.clear", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.fixAll", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.dashboard", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.toggleDelta", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.filterFindings", "when": "view == skylosFindings", "group": "navigation" },
        { "command": "skylos.clearFilter", "when": "view == skylosFindings && skylos.filterActive", "group": "navigation" },
        { "command": "skylos.refreshCommandCenter", "when": "view == skylosCommandCenter", "group": "navigation" },
        { "command": "skylos.commandCenterRestoreTriaged", "when": "view == skylosCommandCenter", "group": "navigation" },
        { "command": "skylos.clearChat", "when": "view == skylosChatPanel", "group": "navigation" }
      ],
      "view/item/context": [
        { "command": "skylos.showFindingDetail", "when": "viewItem == skylosFinding", "group": "inline" },
        { "command": "skylos.chatAboutFinding", "when": "viewItem == skylosFinding", "group": "inline" },
        { "command": "skylos.commandCenterOpenDetail", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterAction", "group": "inline" },
        { "command": "skylos.commandCenterOpenDetail", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterActionSafeFix", "group": "inline" },
        { "command": "skylos.commandCenterApplySafeFix", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterActionSafeFix", "group": "inline" },
        { "command": "skylos.commandCenterSnooze", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterAction", "group": "navigation" },
        { "command": "skylos.commandCenterSnooze", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterActionSafeFix", "group": "navigation" },
        { "command": "skylos.commandCenterDismiss", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterAction", "group": "navigation" },
        { "command": "skylos.commandCenterDismiss", "when": "view == skylosCommandCenter && viewItem == skylosCommandCenterActionSafeFix", "group": "navigation" }
      ],
      "editor/context": [
        { "command": "skylos.scan", "group": "skylos" },
        { "command": "skylos.scanFile", "group": "skylos" }
      ],
      "explorer/context": [
        { "command": "skylos.scanFile", "group": "skylos" }
      ]
    },
    "keybindings": [
      {
        "command": "skylos.scan",
        "key": "ctrl+alt+s",
        "mac": "cmd+alt+s",
        "when": "editorTextFocus"
      },
      {
        "command": "skylos.fixAll",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "skylos.nextFinding",
        "key": "ctrl+alt+]",
        "mac": "cmd+alt+]"
      },
      {
        "command": "skylos.prevFinding",
        "key": "ctrl+alt+[",
        "mac": "cmd+alt+["
      }
    ],
    "viewsWelcome": [
      {
        "view": "skylosFindings",
        "contents": "No security findings yet.\n[Run Scan](command:skylos.scan)\n[Open Settings](command:workbench.action.openSettings?%5B%22skylos%22%5D)"
      },
      {
        "view": "skylosCommandCenter",
        "contents": "No active command center state yet.\n[Refresh Command Center](command:skylos.refreshCommandCenter)\nRun `skylos agent watch .` in a terminal for continuous updates.\n[Restore Triaged Actions](command:skylos.commandCenterRestoreTriaged)"
      }
    ],
    "configuration": {
      "title": "Skylos",
      "properties": {
        "skylos.path": {
          "type": "string",
          "default": "skylos",
          "description": "Path to the skylos executable"
        },
        "skylos.confidence": {
          "type": "number",
          "default": 80,
          "minimum": 0,
          "maximum": 100,
          "description": "Confidence threshold, lower will show more"
        },
        "skylos.excludeFolders": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["venv", ".venv", "build", "dist", ".git", "__pycache__", "node_modules", ".next"],
          "description": "Folders to exclude"
        },
        "skylos.enableSecrets": {
          "type": "boolean",
          "default": true,
          "description": "Include secrets scanning"
        },
        "skylos.enableDanger": {
          "type": "boolean",
          "default": true,
          "description": "Dangerous pattern checks"
        },
        "skylos.enableQuality": {
          "type": "boolean",
          "default": true,
          "description": "Include code quality checks"
        },
        "skylos.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Auto scan the saved file and update its findings without rescanning the whole workspace"
        },
        "skylos.scanOnOpen": {
          "type": "boolean",
          "default": true,
          "description": "Auto scan the first supported file you open in the session"
        },
        "skylos.showPopup": {
          "type": "boolean",
          "default": true,
          "description": "Show a toast for critical/high workspace findings"
        },
        "skylos.maxProblems": {
          "type": "number",
          "default": 200,
          "minimum": 25,
          "maximum": 2000,
          "description": "Maximum findings to publish into the Problems view across the workspace"
        },
        "skylos.maxProblemsPerFile": {
          "type": "number",
          "default": 50,
          "minimum": 5,
          "maximum": 500,
          "description": "Maximum findings per file to publish into the Problems view"
        },
        "skylos.maxTreeFindings": {
          "type": "number",
          "default": 200,
          "minimum": 25,
          "maximum": 2000,
          "description": "Maximum findings to show in the Findings sidebar before truncating"
        },
        "skylos.maxTreeFindingsPerFile": {
          "type": "number",
          "default": 25,
          "minimum": 5,
          "maximum": 250,
          "description": "Maximum findings per file to show in the Findings sidebar"
        },
        "skylos.maxDecorationsPerFile": {
          "type": "number",
          "default": 25,
          "minimum": 5,
          "maximum": 250,
          "description": "Maximum findings per file to decorate inline with hover/code lenses"
        },
        "skylos.showDeadCodeInProblems": {
          "type": "boolean",
          "default": false,
          "description": "Publish dead code findings into the Problems view"
        },
        "skylos.commandCenterLimit": {
          "type": "number",
          "default": 10,
          "minimum": 3,
          "maximum": 50,
          "description": "Maximum ranked actions to show in the Command Center view"
        },
        "skylos.commandCenterRefreshOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Refresh the repo-level Command Center when the extension loads"
        },
        "skylos.commandCenterRefreshOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Refresh the repo-level Command Center after saving a supported file"
        },
        "skylos.commandCenterStateFile": {
          "type": "string",
          "default": "",
          "description": "Optional custom path to the Skylos agent state file. Leave empty to use .skylos/agent_state.json in the workspace root."
        },
        "skylos.idleMs": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "description": "Milliseconds of idle time before AI auto-analysis"
        },
        "skylos.popupCooldownMs": {
          "type": "number",
          "default": 8000,
          "minimum": 1000,
          "description": "Cooldown between popup alerts (ms)"
        },
        "skylos.aiProvider": {
          "type": "string",
          "enum": ["openai", "anthropic", "local"],
          "default": "openai",
          "enumDescriptions": [
            "OpenAI (cloud)",
            "Anthropic (cloud)",
            "Local AI server (Ollama, LM Studio, LocalAI, vLLM — any OpenAI-compatible endpoint)"
          ],
          "description": "AI provider for code analysis and fixes"
        },
        "skylos.openaiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com",
          "description": "Base URL for OpenAI API (only used when aiProvider is 'openai')"
        },
        "skylos.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key"
        },
        "skylos.openaiModel": {
          "type": "string",
          "default": "gpt-4o",
          "description": "OpenAI model to use"
        },
        "skylos.localBaseUrl": {
          "type": "string",
          "default": "",
          "description": "URL of your local AI server (e.g. http://localhost:11434 for Ollama, http://localhost:1234 for LM Studio)"
        },
        "skylos.localModel": {
          "type": "string",
          "default": "",
          "description": "Model name on your local server (e.g. llama3.1, deepseek-coder, kimi)"
        },
        "skylos.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for AI features"
        },
        "skylos.anthropicModel": {
          "type": "string",
          "default": "claude-sonnet-4-20250514",
          "description": "Anthropic model to use"
        },
        "skylos.streamingInline": {
          "type": "boolean",
          "default": true,
          "description": "Show streaming inline ghost text during AI analysis"
        },
        "skylos.enableDeadCode": {
          "type": "boolean",
          "default": true,
          "description": "Show dead code findings (unused functions, imports, classes, variables)"
        },
        "skylos.showDeadParams": {
          "type": "boolean",
          "default": false,
          "description": "Show unused parameter findings (noisy in codebases with callbacks/interfaces)"
        },
        "skylos.autoFixMaxFindings": {
          "type": "number",
          "default": 50,
          "minimum": 1,
          "maximum": 200,
          "description": "Maximum findings to auto-fix in one run (prevents API bill explosions)"
        },
        "skylos.diffBase": {
          "type": "string",
          "default": "origin/main",
          "description": "Git ref used as the base for delta mode (e.g. origin/main, origin/develop, HEAD~5)"
        },
        "skylos.fixPreviewFirst": {
          "type": "boolean",
          "default": true,
          "description": "Always show a diff preview before applying AI fixes"
        },
        "skylos.postFixCommand": {
          "type": "string",
          "default": "",
          "description": "Shell command to run after applying an AI fix (e.g. 'npm test', 'pytest -x'). Leave empty to skip."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.87.0",
    "typescript": "^5.0.0"
  }
}
